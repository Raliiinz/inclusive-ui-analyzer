<idea-plugin>
    <id>com.example.inclusive-ui-analyzer</id>
    <name>Inclusive UI Analyzer</name>
    <version>1.0.0</version>
    <vendor email="support@yourcompany.com" url="https://www.yourcompany.com">YourCompany</vendor>

    <description><![CDATA[
      Analyzes Android UI for accessibility issues
    ]]></description>

    <change-notes><![CDATA[
      Initial release
    ]]></change-notes>

    <idea-version since-build="242" until-build="253.*"/>

    <!-- Зависимости -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>com.intellij.modules.xml</depends>

    <!-- Расширения -->
    <extensions defaultExtensionNs="com.intellij">

        <postStartupActivity implementation="com.example.inclusiveuianalyzer.inspection.ProjectAnalyzerStartupActivity"/>
        <toolWindow
                id="Accessibility Report"
                anchor="right"
                factoryClass="com.example.inclusiveuianalyzer.report.AccessibilityReportToolWindowFactory"/>
        <localInspection
                language=""
                groupPath="Android"
                groupName="Accessibility"
                displayName="Inclusive UI Analysis"
                shortName="InclusiveUI"
                implementationClass="com.example.inclusiveuianalyzer.inspection.InclusiveAccessibilityInspection"
                level="WARNING"
                enabledByDefault="true"
                runForWholeFile="true"/>
    </extensions>
</idea-plugin>
